# ---- Database ----
MONGODB_URI=                 # MongoDB connection string (Atlas or local)
DNS_SERVERS=1.1.1.1,8.8.8.8  # only for mongodb+srv:// if you hit
                             # "querySrv ECONNREFUSED" (Node DNS issue)

# ---- Admin auth (password + JWT cookie) ----
JWT_SECRET=                  # long random string used to sign the admin session
ADMIN_PASSWORD_HASH=         # bcrypt hash of the admin password (see README)
ADMIN_2FA_ENABLED=false      # optional; reserved for future email 2FA

# ---- reCAPTCHA v3 (optional; enforced on /api/admin/login only when set) ----
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# ---- Public site ----
SITE_URL=https://tojiboyevumidjon.uz   # used by next-sitemap
NEXT_PUBLIC_CHAT_URL=                  # n8n chat webhook URL
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=   # Google Analytics measurement id

# ---- Docker ----
CONTAINER_PORT=3000          # host port mapped to the container
